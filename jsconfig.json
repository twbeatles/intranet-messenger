{
  "compilerOptions": {
    "target": "ES2021",
    "lib": [
      "ES2021",
      "DOM"
    ],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "none",
    "maxNodeModuleJsDepth": 0
  },
  "include": [
    "static/js/core/**/*.js",
    "static/js/app.js",
    "static/js/auth.js",
    "static/js/features.js",
    "static/js/message-upload.js",
    "static/js/messages.js",
    "static/js/notification.js",
    "static/js/profile.js",
    "static/js/rooms.js",
    "static/js/socket-handlers.js",
    "static/js/storage.js",
    "static/js/theme.js",
    "static/js/toast.js",
    "static/js/utils.js",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "static/js/**/*.min.js",
    "static/js/experimental/**/*"
  ]
}
